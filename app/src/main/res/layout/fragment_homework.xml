<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FFFFFF"
    tools:context=".homework">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:background="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="16dp">


            <!-- Arabic -->
            <androidx.cardview.widget.CardView
                android:layout_width="374dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="6dp"
                android:background="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <TextView
                    android:fontFamily="@font/kiteone"
                    android:id="@+id/arabicHomeworkTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Arabic Homework"
                    android:textColor="#47779F"
                    android:textSize="16sp" />
            </androidx.cardview.widget.CardView>

            <!-- English -->
            <androidx.cardview.widget.CardView
                android:layout_width="374dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="6dp"
                android:background="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <TextView
                    android:fontFamily="@font/kiteone"
                    android:id="@+id/englishHomeworkTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="English Homework"
                    android:textColor="#47779F"
                    android:textSize="16sp" />
            </androidx.cardview.widget.CardView>

            <!-- Math -->
            <androidx.cardview.widget.CardView
                android:layout_width="374dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="6dp"
                android:background="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <TextView
                    android:fontFamily="@font/kiteone"
                    android:id="@+id/mathHomeworkTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Math Homework"
                    android:textColor="#47779F"
                    android:textSize="16sp" />
            </androidx.cardview.widget.CardView>

            <!-- Science -->
            <androidx.cardview.widget.CardView
                android:layout_width="374dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="6dp"
                android:background="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <TextView
                    android:fontFamily="@font/kiteone"
                    android:id="@+id/scienceHomeworkTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Science Homework"
                    android:textColor="#47779F"
                    android:textSize="16sp" />
            </androidx.cardview.widget.CardView>

            <!-- Islamic -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_name"
                android:layout_width="374dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="6dp"
                android:background="@color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <TextView
                    android:fontFamily="@font/kiteone"
                    android:id="@+id/islamicHomeworkTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Islamic Homework"
                    android:textColor="#47779F"
                    android:textSize="16sp" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</FrameLayout>