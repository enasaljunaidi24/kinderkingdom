<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".dailymenu">

    <ImageView
        android:id="@+id/settingView"
        android:layout_width="20dp"
        android:layout_height="19dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/settingicon" />

    <ImageView
        android:id="@+id/bellView"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="36dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/bellicon" />



    <TextView
        android:id="@+id/menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="124dp"
        android:fontFamily="@font/kiteone"
        android:text="My Daily Menu"
        android:textColor="@color/blue"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <ScrollView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:background="#FFFFFF"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">


            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:shrinkColumns="1"
                android:stretchColumns="1">

                <!-- Header -->
                <TableRow
                    android:background="#F2B705"
                    android:padding="6dp">

                    <TextView
                        android:fontFamily="@font/kiteone"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Item"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                    <TextView
                        android:fontFamily="@font/kiteone"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="Price"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                </TableRow>

                <!-- Items with emoji on the right -->


                <TableRow android:padding="8dp">

                    <TextView
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/kiteone"
                        android:textColor="#47779F"
                        android:padding="8dp"
                        android:text="🌯     Falafel Sandwich"
                        android:textSize="16sp" />

                    <TextView
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="0.60 JD"
                        android:textSize="16sp" />
                </TableRow>

                <TableRow android:padding="8dp">

                    <TextView
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:padding="8dp"
                        android:text="🥐     Pastries"
                        android:textSize="16sp" />

                    <TextView
                        android:fontFamily="@font/kiteone"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="0.50 JD"
                        android:textColor="#47779F"
                        android:textSize="16sp" />
                </TableRow>




                <TableRow android:padding="8dp">

                    <TextView
                        android:padding="8dp"
                        android:text="🍎     Apple"
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />

                    <TextView
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="0.40 JD"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />
                </TableRow>

                <TableRow android:padding="8dp">

                    <TextView
                        android:padding="8dp"
                        android:text="🍌     Banana"
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />

                    <TextView
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="0.35 JD"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />
                </TableRow>

                <TableRow android:padding="8dp">

                    <TextView
                        android:padding="8dp"
                        android:text="🥛     Yogurt "
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />

                    <TextView
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="0.50 JD"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />
                </TableRow>

                <TableRow android:padding="8dp">

                    <TextView
                        android:padding="8dp"
                        android:text="🧃     Fruit Juice Box"
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />

                    <TextView
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="0.45 JD"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />
                </TableRow>
                <TableRow android:padding="8dp">

                    <TextView
                        android:padding="8dp"
                        android:text="🥤      Milk "
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />

                    <TextView
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="0.25 JD"
                        android:textSize="16sp" />
                </TableRow>

                <TableRow android:padding="8dp">

                    <TextView
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:padding="8dp"
                        android:text="💧     Water"
                        android:textSize="16sp" />

                    <TextView
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="0.25 JD"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />
                </TableRow>

                <TableRow android:padding="8dp">

                    <TextView
                        android:padding="8dp"
                        android:text="🍩     Donut"
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />

                    <TextView
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="0.60 JD"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />
                </TableRow>
                <TableRow android:padding="8dp">

                    <TextView
                        android:padding="8dp"
                        android:text="🍪     Cookies"
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />

                    <TextView
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="0.30 JD"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:textSize="16sp" />
                </TableRow>
                <TableRow android:padding="8dp">

                    <TextView
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:padding="8dp"
                        android:text="🍟     Chips "
                        android:textSize="16sp" />

                    <TextView
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="0.25 JD"

                        android:textSize="16sp" />
                </TableRow>

                <TableRow android:padding="8dp">

                    <TextView
                        android:layout_marginStart="30dp"
                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:padding="8dp"
                        android:text="🍫     Chocolate"

                        android:textSize="16sp" />

                    <TextView

                        android:fontFamily="@font/kiteone"
                        android:textColor="@color/blue"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="0.25 JD"
                        android:textSize="16sp" />
                </TableRow>







            </TableLayout>

        </LinearLayout>
    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>