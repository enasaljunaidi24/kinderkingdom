<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".drivers"
    android:background="@color/white">
    <TextView
        android:id="@+id/Drivers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="136dp"
        android:fontFamily="@font/kiteone"
        android:text="@string/drivers"
        android:textColor="@color/blue"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/settingView"
        android:layout_width="20dp"
        android:layout_height="19dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/settingicon" />

    <ImageView
        android:id="@+id/bellView"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="36dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/bellicon" />

    <ScrollView
        android:layout_width="405dp"
        android:layout_height="674dp"
        android:layout_marginTop="68dp"
        android:background="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:columnCount="1"
            android:orientation="horizontal"
            android:padding="8dp">

            <!-- 1️⃣ Information -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_information"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:gravity="center_vertical"
                    android:onClick="informationofdrivers"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="58dp"
                        android:layout_height="50dp"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="16dp"
                        android:backgroundTint="#F4B400"
                        android:src="@drawable/information2" />

                    <TextView
                        android:id="@+id/information"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/kiteone"
                        android:text="@string/Information"
                        android:textColor="@color/blue"
                        android:textSize="18sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="350dp"
                    android:layout_marginTop="25dp"
                    android:src="@drawable/arrowicon" />
            </androidx.cardview.widget.CardView>

            <!-- Attendance & Absences -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_attendance2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:onClick="attendanceandabsenceofdrivers"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="66dp"
                        android:layout_height="54dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="16dp"
                        android:backgroundTint="#F4B400"
                        android:src="@drawable/attendanceandabsences2" />

                    <TextView
                        android:id="@+id/AttendanceAbsences"
                        android:layout_width="183dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/kiteone"
                        android:text="@string/AttendanceAbsences"
                        android:textColor="@color/blue"
                        android:textSize="18sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="350dp"
                    android:layout_marginTop="30dp"
                    android:src="@drawable/arrowicon" />
            </androidx.cardview.widget.CardView>


            <!-- Bus Tours -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_bus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="77dp"
                    android:gravity="center_vertical"
                    android:onClick="bustour"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="82dp"
                        android:layout_height="61dp"
                        android:layout_marginEnd="16dp"
                        android:backgroundTint="#F4B400"
                        android:src="@drawable/busbutton2" />

                    <TextView
                        android:id="@+id/BusTour"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/kiteone"
                        android:text="@string/BusTour"

                        android:textColor="@color/blue"
                        android:textSize="18sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="350dp"
                    android:layout_marginTop="30dp"
                    android:src="@drawable/arrowicon" />
            </androidx.cardview.widget.CardView>


        </GridLayout>
    </ScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>